# Cloudflare Pages security headers (applied to every response).
# Harmless on other hosts that ignore this file.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Content-Security-Policy: default-src 'none'; script-src 'unsafe-inline' https://plausible.thompsonblack.us; style-src 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' data: blob:; font-src 'self' data: blob:; connect-src https://plausible.thompsonblack.us; worker-src blob:; child-src blob:; base-uri 'none'; form-action 'none'; frame-ancestors 'none'
